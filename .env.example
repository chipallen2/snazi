# =============================================================================
# snazi environment
# =============================================================================
# This product manages an approve/deny LIST only. It stores NO messages.
#
# Web (packages/web): set these as Vercel env vars (production).
# Mac CLI (packages/snazi): uses ~/.snazi/config.json, NOT a .env.

# --- Supabase (server-side only; never expose the service key to the browser) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Auth secret -------------------------------------------------------------
# HMAC secret that signs (a) dashboard session cookies and (b) /decide
# capability links. Generate with: openssl rand -hex 32
SOUP_NAZI_AUTH_SECRET=generate-me

# --- Tuning (optional) -------------------------------------------------------
# Default country calling code used to turn a bare national number a human types
# (e.g. "(555) 123-4567") into the E.164 key chat.db uses ("+1..."). Digits
# only; defaults to "1" (North America). Set to your region; international users
# should enter full "+" E.164 numbers. MUST match the Mac CLI's value (below).
SNAZI_DEFAULT_COUNTRY_CODE=1
# Lifetime of a one-tap /decide link, in milliseconds. These links are
# forwardable bearer tokens, so keep this short. Defaults to 86400000 (24h).
SNAZI_DECIDE_TTL_MS=86400000

# NOTE: This service is multi-tenant. There are NO global API/admin/password
# env vars. Users sign up at /signup; each account gets its own per-user READ
# token (shown on the dashboard Account page) for the Mac CLI.

# =============================================================================
# snazi CLI (packages/snazi) — ~/.snazi/config.json
# =============================================================================
# Don't hand-write this — run `snazi init` (cross-platform: macOS/Windows/Linux).
# It writes ~/.snazi/config.json for you, e.g.:
# {
#   "apiUrl": "https://snazi.dev",
#   "apiKey": "<your account READ token from the dashboard Account page>",
#   "channels": ["imessage"],
#   "checkCacheTtlMs": 300000
# }
# Then run `snazi doctor` to verify config, connectivity, and channel access.
# There is no admin key: approvals happen in the dashboard or via /decide links.
#
# Phone normalization: the CLI reads SNAZI_DEFAULT_COUNTRY_CODE from its
# environment (default "1") so a number you type without "+" maps to the same
# E.164 key chat.db uses. Keep it equal to the web app's value above.
#
# Approval cache: check/read/list-new cache approved/denied status on disk
# (~/.snazi/check-cache.json) for checkCacheTtlMs (default 300000 = 5 min; env
# SNAZI_CHECK_CACHE_TTL_MS overrides; 0 disables). 'unknown' is never cached.
# After revoking someone, run `snazi cache clear` (or use --fresh) for an
# instant live check. No message content is ever cached.
