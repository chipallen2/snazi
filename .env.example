# =============================================================================
# soup-nazi-agent environment
# =============================================================================
# This product manages an approve/deny LIST only. It stores NO messages.
#
# Web (packages/web): set these as Vercel env vars (production).
# Mac CLI (packages/snazi): uses ~/.snazi/config.json, NOT a .env.

# --- Supabase (server-side only; never expose the service key to the browser) ---
SUPABASE_URL=https://cmohqhotfywhmgikeatc.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- API keys (generate with: openssl rand -hex 32) --------------------------
# Read/check key — used by the Mac CLI: GET /api/senders, GET /api/senders/check
SOUP_NAZI_API_KEY=generate-me
# Admin key — used by the dashboard server actions: POST/DELETE /api/senders
SOUP_NAZI_ADMIN_KEY=generate-me

# =============================================================================
# Mac iMessage CLI (packages/snazi) — ~/.snazi/config.json
# =============================================================================
# {
#   "apiUrl": "https://soup-nazi-agent.vercel.app",
#   "apiKey": "<SOUP_NAZI_API_KEY>",    // the read/check key above
#   "adminKey": "<SOUP_NAZI_ADMIN_KEY>", // needed for approve/deny
#   "channels": ["imessage"]
# }
